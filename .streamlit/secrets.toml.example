# Copy to .streamlit/secrets.toml for local dev
# On Streamlit Cloud: App settings → Secrets

# Optional — only set these when you have a real Supabase project.
# Do NOT leave YOUR_PROJECT placeholders; they cause DNS errors.
# SUPABASE_URL = "https://xxxx.supabase.co"
# SUPABASE_KEY = "your_service_role_key"

# Manager tab password (full access). Also seeds first Admin user (username: admin) if none exist.
APP_PASSWORD = "choose-a-strong-admin-password"

# Shared technician login — Check Out / In, Out Now, Catalog (view), History only
TECH_PASSWORD = "choose-a-shared-tech-password"
